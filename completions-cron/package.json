{
	"name": "resource-completions-cron",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "wrangler dev --test-scheduled",
		"start": "wrangler dev --test-scheduled",
		"cf-typegen": "wrangler types",
    "start:cron": "curl http://localhost:8787/__scheduled?cron=*+*+*+*+*",
