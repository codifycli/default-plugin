    "test:completions": "../node_modules/.bin/tsx src/test-completions.ts"
  },
	"devDependencies": {
    "@types/node": "^24.10.1",
		"typescript": "^5.5.2",
    "supabase": "^2.45.5",
		"wrangler": "^4.47.0"
	},
	"dependencies": {
    "@supabase/supabase-js": "^2.58.0",
		"yjs": "^13.6.27"
	}
}
